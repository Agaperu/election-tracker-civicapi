{
    "name": "civicapi-election-dashboard",
    "private": true,
    "workspaces": ["client", "server"],
    "scripts": {
      "dev": "concurrently -n server,client -c auto \"npm:dev --workspace=server\" \"npm:dev --workspace=client\"",
      "build": "npm run build --workspace=client",
      "start": "node server/index.js"
    },
    "devDependencies": {
      "concurrently": "^9.0.0"
    }
  }
  